{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"paths": {
			"webextension-polyfill": ["./stubs/webextension-polyfill.ts"]
		},
		"baseUrl": "."
	},
	"include": ["./**/*.ts"]
}
